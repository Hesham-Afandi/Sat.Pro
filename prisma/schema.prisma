// 1. إعدادات الـ Generator (توليد الكود)
generator client {
  provider = "prisma-client-js"
}

// 2. إعدادات الداتابيز (مهم جداً: PostgreSQL لـ Neon)
datasource db {
  provider = "postgresql"  // ✅ غيرناها من sqlite لـ postgresql
  url      = env("DATABASE_URL")
}

// 3. موديل المستخدمين (User)
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("student") // student or admin
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  courses       Course[]  @relation("CourseCreator")
  examResults   ExamResult[]
}

// 4. موديل الكورسات (Course)
model Course {
  id          String   @id @default(cuid())
  title       String
  description String?
  subject     String?
  category    String?
  level       String   @default("beginner")
  image       String?
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lessons     Lesson[]
  exams       Exam[]
  creator     User?    @relation("CourseCreator", fields: [creatorId], references: [id])
  creatorId   String?
}

// 5. موديل الدروس (Lesson)
model Lesson {
  id          String   @id @default(cuid())
  title       String
  description String?
  videoUrl    String?
  duration    String?
  order       Int      @default(0)
  completed   Boolean  @default(false)
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// 6. موديل الامتحانات (Exam)
model Exam {
  id             String   @id @default(cuid())
  title          String
  subject        String?
  duration       String?
  totalQuestions Int      @default(0)
  courseId       String
  course         Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  questions      Question[]
  results        ExamResult[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// 7. موديل الأسئلة (Question)
model Question {
  id          String   @id @default(cuid())
  text        String
  options     String?  // بنخليها String عشان الـ migration script بتاعك
  correct     String
  explanation String?
  examId      String
  exam        Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// 8. موديل نتائج الامتحان (ExamResult)
model ExamResult {
  id        String   @id @default(cuid())
  score     Float
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  examId    String
  exam      Exam     @relation(fields: [examId], references: [id])

  createdAt DateTime @default(now())
}

// --- موديلات NextAuth (ضرورية لتسجيل الدخول) ---

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}