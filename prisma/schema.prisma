// 1. إعداد قاعدة البيانات (SQLite)
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// 2. جدول المستخدمين (User)
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?   // صورة البروفايل (Profile Image)
  password      String?   // الباسورد (للدخول بالإيميل)
  
  // حقول إضافية للبروفايل
  role          String    @default("student") // دور المستخدم (student, admin)
  phone         String?
  address       String?
  grade         String?   // الصف الدراسي
  school        String?
  bio           String?
  coverImage    String?   // صورة الغلاف
  
  // العلاقات
  accounts      Account[]
  sessions      Session[]
  results       ExamResult[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// 3. جداول NextAuth (ضرورية لتسجيل الدخول بجوجل وغيرها)
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id         Int      @id @default(autoincrement())
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// 4. جدول المواد (Courses)
model Course {
  id          String   @id @default(cuid())
  title       String
  description String?
  color       String?   // لون الخلفية
  image       String?   // أيقونة أو صورة المادة
  instructor  String?
  
  lessons     Lesson[]
  exams       Exam[]
}

// 5. جدول الدروس (Lessons)
model Lesson {
  id        Int     @id @default(autoincrement())
  title     String
  duration  String?
  videoUrl  String?
  completed Boolean @default(false)
  
  courseId  String
  course    Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

// 6. جدول الامتحانات (Exams)
model Exam {
  id        String   @id @default(cuid())
  title     String
  duration  String?
  subject   String?
  
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  
  questions Question[]
  results   ExamResult[]
}

// 7. جدول الأسئلة (Questions)
model Question {
  id       String @id @default(cuid())
  text     String
  options  String // نخزن الخيارات كـ JSON String
  correct  String
  explanation String?

  examId   String
  exam     Exam   @relation(fields: [examId], references: [id], onDelete: Cascade)
}

// 8. جدول نتائج الامتحانات (ExamResults)
model ExamResult {
  id            String   @id @default(cuid())
  score         Int      // الدرجة
  totalQuestions Int     // عدد الأسئلة
  answers       String   // إجابات الطالب (JSON)
  passed        Boolean  @default(false)
  
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  examId        String
  exam          Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)

  createdAt     DateTime @default(now())
}